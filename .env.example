# ---------- 上游 ----------
UPSTREAM_BASE=https://haochi.moon9.cloud/v1
UPSTREAM_KEY=sk-your-key
UPSTREAM_MODEL=gpt-image-2
PRICE_CENTS=5

# ---------- Claude 中转（图标矢量生成）----------
CLAUDE_BASE=https://claude.moon9.cloud
CLAUDE_KEY=sk-your-claude-key
CLAUDE_MODEL=kiro-opus-4.7

# ---------- OpenRouter Recraft（高级矢量生成）----------
OPENROUTER_BASE=https://openrouter.ai/api/v1
OPENROUTER_KEY=sk-or-v1-your-key
RECRAFT_MODEL=recraft/recraft-v4.1-pro-vector
OPENROUTER_REFERER=https://image2.zeabur.app
OPENROUTER_TITLE=image2
PRICE_RECRAFT_CENTS=300

# ---------- 鉴权 ----------
ADMIN_PASSWORD=change-me
SESSION_SECRET=please-fill-32-bytes-random

# ---------- PostgreSQL ----------
# Zeabur 会自动注入 DATABASE_URL，本地手填
DATABASE_URL=postgres://postgres:postgres@localhost:5432/image2

# ---------- 对象存储 (MinIO / S3) ----------
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=images
S3_REGION=us-east-1

# ---------- 服务 ----------
PORT=8000
